# Copy this file to .env.local and fill in your Supabase project's values.
# Both are safe to expose in the client bundle: the anon key is public by design,
# and Row-Level Security (see supabase/schema.sql) is what protects the data.
# Leave .env.local absent to run the app anonymously (local-only, no sign-in).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
